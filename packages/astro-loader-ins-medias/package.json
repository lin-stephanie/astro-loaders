{
  "name": "astro-loader-ins-medias",
  "version": "1.0.1",
  "description": "Astro loader for loading Instagram medias.",
  "author": "Stephanie Lin <norwaywoods047@gmail.com>",
  "license": "MIT",
  "keywords": [
    "withastro",
    "astro-loader",
    "ins",
    "instagram",
    "media",
    "medias"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lin-stephanie/astro-loaders.git",
    "directory": "packages/astro-loader-ins-medias"
  },
  "homepage": "https://github.com/lin-stephanie/astro-loaders/blob/main/packages/astro-loader-ins-medias/",
  "bugs": "https://github.com/lin-stephanie/astro-loaders/issues",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./live": {
      "types": "./dist/live.d.ts",
      "import": "./dist/live.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup src/index.ts src/live.ts --format esm --dts --watch --external astro:env/server",
    "build": "tsup src/index.ts src/live.ts --format esm --dts --clean --treeshake --external astro:env/server",
    "check": "publint && pnpm pack | grep '.tgz$' | xargs attw --profile node16 --ignore-rules=cjs-resolves-to-esm",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "astro": ">=4.14.0 <7.0.0"
  }
}
